---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section id="about" class="border-b border-ink/10 bg-soft/40">
  <div class="mx-auto max-w-3xl px-6 py-24 text-center">
    <p class="text-xs uppercase tracking-[0.2em] text-muted mb-6">{t('about.subtitle')}</p>
    <h2 class="font-serif text-4xl md:text-5xl leading-tight text-ink">
      {t('about.title')}
    </h2>
    <p class="mt-8 text-lg leading-relaxed text-ink/80" set:html={t('about.description')} />
  </div>
</section>
