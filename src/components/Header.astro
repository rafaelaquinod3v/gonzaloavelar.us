---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';
import { languages } from '../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const links = [
  { href: '#about', label: t('nav.about') },
  { href: '#services', label: t('nav.services') },
  { href: '#contact', label: t('nav.contact') },
];
---

<header class="border-b border-ink/10 bg-paper">
  <div class="mx-auto max-w-6xl px-6 py-5 flex items-center justify-between">
    <a href={translatePath('/')} class="text-lg font-serif font-medium tracking-tight">
      Lic. Gonzalo Avelar
    </a>
    <div class="flex items-center gap-8">
      <nav aria-label="Primary">
        <ul class="flex items-center gap-8 text-sm">
          {links.map((l) => (
            <li>
              <a
                href={l.href}
                class="text-ink/70 hover:text-ink transition-colors underline-offset-4 hover:underline"
              >
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="flex items-center gap-3 border-l border-ink/10 pl-8" aria-label="Language selector">
        {Object.entries(languages).map(([code, label], index) => (
          <>
            <a
              href={translatePath('/', code)}
              class={`text-[10px] font-bold uppercase tracking-[0.2em] transition-colors ${lang === code ? 'text-ink' : 'text-ink/40 hover:text-ink'}`}
              aria-current={lang === code ? 'page' : undefined}
            >
              {code}
            </a>
            {index < Object.keys(languages).length - 1 && (
              <span class="text-ink/10 text-[10px]" aria-hidden="true">|</span>
            )}
          </>
        ))}
      </div>
    </div>
  </div>
</header>
