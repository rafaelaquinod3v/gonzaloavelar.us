---
import { getLangFromUrl, useTranslations, useTranslatedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const translatePath = useTranslatedPath(lang);

const links = [
  { href: '#about', label: t('nav.about') },
  { href: '#services', label: t('nav.services') },
  { href: '#contact', label: t('nav.contact') },
];
---

<header class="border-b border-ink/10 bg-paper">
  <div class="mx-auto max-w-6xl px-6 py-5 flex items-center justify-between">
    <a href={translatePath('/')} class="text-lg font-serif font-medium tracking-tight">
      Lic. Gonzalo Avelar
    </a>
    <nav aria-label="Primary">
      <ul class="flex items-center gap-8 text-sm">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class="text-ink/70 hover:text-ink transition-colors underline-offset-4 hover:underline"
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
