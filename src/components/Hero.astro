---
import { Image } from 'astro:assets';
import gonzalo from '../assets/gonzalo.jpg';
import { WHATSAPP_URL } from './WhatsApp.astro';
---

<section class="border-b border-ink/10">
  <div class="mx-auto max-w-6xl px-6 py-20 md:py-28 grid md:grid-cols-2 gap-16 items-center">
    <div>
      <p class="text-xs uppercase tracking-[0.2em] text-muted mb-6">
        Psychologist · Speaker · Logotherapist
      </p>
      <h1 class="font-serif text-5xl md:text-6xl leading-[1.05] text-ink">
        You will be whatever<br />you want to be.
      </h1>
      <p class="mt-6 max-w-prose text-lg leading-relaxed text-ink/75">
        You don\u2019t need to see to be happy. Reclaim your dignity and autonomy
        by transforming your reality from an active position.
      </p>
      <div class="mt-10 flex flex-wrap gap-4">
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center rounded-full bg-ink text-paper px-7 py-3.5 text-sm font-medium hover:bg-ink/85 transition-colors"
        >
          Book a conversation
        </a>
        <a
          href="#about"
          class="inline-flex items-center justify-center rounded-full border border-ink/20 px-7 py-3.5 text-sm font-medium hover:border-ink transition-colors"
        >
          Learn more
        </a>
      </div>
    </div>
    <div class="relative">
      <div class="absolute -inset-4 bg-soft rounded-sm -z-10" aria-hidden="true"></div>
      <Image
        src={gonzalo}
        alt="Portrait of Lic. Gonzalo Avelar — a serene blind psychologist in a dark suit."
        widths={[480, 768, 1024]}
        sizes="(max-width: 768px) 100vw, 480px"
        class="w-full h-auto object-cover grayscale"
        loading="eager"
      />
    </div>
  </div>
</section>
