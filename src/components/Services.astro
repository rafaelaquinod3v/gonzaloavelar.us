---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const services = [
  {
    n: '01',
    title: t('services.s1_title'),
    body: t('services.s1_body'),
  },
  {
    n: '02',
    title: t('services.s2_title'),
    body: t('services.s2_body'),
  },
  {
    n: '03',
    title: t('services.s3_title'),
    body: t('services.s3_body'),
  },
];
---

<section id="services" class="border-b border-ink/10">
  <div class="mx-auto max-w-6xl px-6 py-24">
    <div class="max-w-2xl mb-16">
      <p class="text-xs uppercase tracking-[0.2em] text-muted mb-6">{t('services.subtitle')}</p>
      <h2 class="font-serif text-4xl md:text-5xl leading-tight text-ink">
        {t('services.title')}
      </h2>
    </div>
    <div class="grid md:grid-cols-3 gap-px bg-ink/10 border border-ink/10">
      {services.map((s) => (
        <article class="bg-paper p-10 flex flex-col gap-6 hover:bg-soft/60 transition-colors">
          <span class="text-sm font-mono text-muted">{s.n}</span>
          <h3 class="font-serif text-2xl text-ink leading-snug">{s.title}</h3>
          <p class="text-ink/75 leading-relaxed">{s.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>
